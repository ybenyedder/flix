<!-- Leanback launcher banner (320x180dp), shown in the Android TV home-screen
     row instead of a regular launcher icon. Kept as a plain vector (no text
     glyph rendering needed) so it always rasterizes crisply at the fixed
     banner size regardless of density. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">
    <path
        android:fillColor="#141414"
        android:pathData="M0,0h320v180h-320z" />
    <path
        android:fillColor="#E50914"
        android:pathData="M120,50h80v80h-80z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M148,68 L148,112 L188,90 Z" />
</vector>
