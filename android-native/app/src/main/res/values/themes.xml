<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash/host theme. The actual UI is fully Compose; this only styles the
         window before Compose takes over (dark, edge-to-edge). -->
    <style name="Theme.Flix" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/flix_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
