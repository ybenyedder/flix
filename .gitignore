# dependencies
node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/

# desktop (electron) build output
/dist-desktop/

# deployable server bundle (scripts/prepare-standalone.mjs)
/dist-standalone/
/flix-standalone-*.tar.gz

# android-native (Kotlin/Compose) — build output only
/android-native/.gradle/
/android-native/.kotlin/
/android-native/build/
/android-native/*/build/
/android-native/local.properties

# runtime data (SQLite db, image/transcode cache, video library)
/data/
/videos/
# *arr download/library tree (docker-compose.arr.yml: movies/, shows/, downloads/)
/media/

# secrets / signing material — never commit new ones. (The two deliberately
# tracked keystores, android-native/app/flix.keystore and
# android-native/tv/flix.keystore, are self-signed app keys kept in-repo on
# purpose so debug/release signing stays stable across machines; this guards
# against ANY other key/cert being added by accident.)
*.pem
*.key
*.jks
*.keystore
*.p12
*.pfx

# env files
.env
.env.local
.env.*
!.env.example

# typescript / next
*.tsbuildinfo
next-env.d.ts

# tooling
.vercel
.claude
/skills/
.agents/

# misc
.DS_Store
# macOS AppleDouble / one-off scratch dotfiles (e.g. the ._q.mjs DB probe) —
# never let one get committed (it also breaks `npm run lint`).
._*
*.log
npm-debug.log*

# VPN — gluetun config generated by Flix, contains the WireGuard PRIVATE key
/vpn/
build/
keystore.properties
android-native/keystore.properties
