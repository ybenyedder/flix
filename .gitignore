# dependencies
node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/

# desktop (electron) build output
/dist-desktop/
# pruned Electron-ABI server copy built by scripts/prepare-desktop.mjs
/dist-electron-server/

# deployable server bundle (scripts/prepare-standalone.mjs)
/dist-standalone/
/flix-standalone-*.tar.gz

# android-native (Kotlin/Compose) — build output only
/android-native/.gradle/
/android-native/.kotlin/
/android-native/build/
/android-native/*/build/
/android-native/local.properties

# runtime data (SQLite db, image/transcode cache, video library)
/data/
/videos/
# *arr download/library tree (docker-compose.arr.yml: movies/, shows/, downloads/)
/media/

# secrets / signing material — never commit any. The Android signing
# keystores (android-native/{app,tv}/flix.keystore) are deliberately NOT in
# the repo: they live on the build machine + CI secrets only, with an
# out-of-repo backup — losing them breaks app-update continuity (users would
# have to uninstall/reinstall), but publishing them would let anyone sign
# "updates" of the app. Their passwords come from keystore.properties
# (ignored below) or ANDROID_KEYSTORE_PWD/ANDROID_KEY_* env vars in CI.
*.pem
*.key
*.jks
*.keystore
*.p12
*.pfx

# env files
.env
.env.local
.env.*
!.env.example

# typescript / next
*.tsbuildinfo
next-env.d.ts

# tooling
.vercel
.claude
/skills/
.agents/

# misc
.DS_Store
# macOS AppleDouble / one-off scratch dotfiles (e.g. the ._q.mjs DB probe) —
# never let one get committed (it also breaks `npm run lint`).
._*
*.log
npm-debug.log*

# VPN — gluetun config generated by Flix, contains the WireGuard PRIVATE key
/vpn/
build/
keystore.properties
android-native/keystore.properties
