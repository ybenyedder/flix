{
  "name": "flix",
  "version": "0.11.0",
  "private": true,
  "description": "Flix — plateforme vidéo self-hosted, 100% locale : bibliothèque SQLite, scan ffprobe/NFO, lecture directe/remux/transcodage adaptatifs, recommandations locales. Web, Electron (Linux/Windows) et Android/Android TV.",
  "main": "desktop/main.js",
  "license": "UNLICENSED",
  "homepage": "https://github.com/ybenyedder/flix",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 4247",
    "build": "next build",
    "start": "NODE_ENV=production next start -p 4247",
    "serve": "NODE_ENV=production node .next/standalone/server.js",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "check": "npm run lint && npm run typecheck && npm run build",
    "icons:gen": "node scripts/gen-icons.mjs",
    "desktop:dev": "FLIX_DESKTOP_DEV=1 electron desktop/main.js",
    "desktop:prepare": "node scripts/prepare-desktop.mjs",
    "desktop:build": "npm run build && npm run desktop:prepare && electron-builder",
    "desktop:build:linux": "npm run build && npm run desktop:prepare && electron-builder --linux",
    "desktop:build:win": "npm run build && npm run desktop:prepare && electron-builder --win"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.0.4",
    "hls.js": "^1.6.2",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tsx": "^4.22.4"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
